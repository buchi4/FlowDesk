# Environment Variables for FlowDesk
# Copy this file to .env and fill in your values

# Slack Bot Token (xoxb-...)
# Get this from api.slack.com/apps > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack Signing Secret
# Get this from api.slack.com/apps > Basic Information
SLACK_SIGNING_SECRET=your-signing-secret

# Slack App-Level Token (xapp-...)
# Required for Socket Mode. Generate at api.slack.com/apps > Basic Information > App-Level Tokens
# Scopes needed: connections:write
SLACK_APP_TOKEN=xapp-your-app-token

# Google Gemini API Key
# Get this from aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Supabase
# Get these from your Supabase project > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Server port (optional, defaults to 3000)
PORT=3000
